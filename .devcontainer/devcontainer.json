{
  "name": "Lingua-Sound-Wave",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-24-bookworm",
  "features": {
    
    "ghcr.io/devcontainers/features/postgresql:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "containerEnv": {
    "DATABASE_URL": "postgresql://postgres:postgres@localhost:5432/dev",
    "PORT": "5000",
    "BASE_PATH": "/"
  },
  "postCreateCommand": "npm install -g pnpm@latest && pnpm install && sudo service postgresql start && sleep 2 && sudo -u postgres psql -c "CREATE DATABASE dev;" 2>/dev/null || true && pnpm -C lib/db push --force",
  "postStartCommand": "bash .devcontainer/start.sh",
  "forwardPorts": [5000, 5173],
  "portsAttributes": {
    "5173": {"label": "Frontend", "onAutoForward": "openBrowser"},
    "5000": {"label": "API"}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "mtxr.sqltools",
        "ms-python.python"
      ]
    }
  }
}
